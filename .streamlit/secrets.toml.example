# Copy this file to `secrets.toml` (same folder) and fill in your key.
# Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY = "your-api-key-here"

# Optional: pin a single Gemini model (overrides the built-in fallback chain).
# By default the app tries gemini-3.5-flash first, then gemini-2.5-flash, then
# Groq. Set this only if you want to force one specific model.
# GEMINI_MODEL = "gemini-2.5-flash"

# Optional fallback: if Gemini errors (quota/429/etc.), calls retry on Groq.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY = "your-groq-api-key-here"
# GROQ_MODEL = "llama-3.3-70b-versatile"
